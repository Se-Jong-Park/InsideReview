package com.jeonju.movie.user.controller;

import javax.servlet.http.HttpSession;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.ResponseBody;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.web.servlet.mvc.support.RedirectAttributes;

import com.jeonju.movie.comm.EncryptUtils;
import com.jeonju.movie.user.service.UserService;
import com.jeonju.movie.user.vo.UserVO;

// クラス宣言(클래스선언)
@Controller
@RequestMapping(value="/user")
public class UserController {
	
	@Autowired
	private UserService uservice;
	
	// 업로드 경로
	private String uploadPath = "C:/upload/profile";
	
	//회원가입 폼
	@RequestMapping(value = "/form")
	public String userForm() {
		System.out.println("UserController userForm() 함수진입 >>> ");
		return "user/form";
	}
	
	//회원가입 처리
	@PostMapping(value = "join")
	public String userjoin(@ModelAttribute UserVO uvo, RedirectAttributes rattrs) {
		System.out.println("Usercontroller userJoin() 함수진입 >>> ");
		System.out.println("uvo >>> " + uvo);
		
		//회원번호 채번
		int maxno = uservice.userMaxno();
		String uno = String.format("U%001d", maxno + 1);
		uvo.setUno(uno);
				
		//비밀번호 암호화
		uvo.setUpw(EncryptUtils.encryptMD5(uvo.getUpw()));
				
		//기본값 세팅
		uvo.setUrole("U");
		uvo.setUdeleteyn('N');
		uvo.setUtempyn("N");
		
		if(uvo.getUprofile() == null || uvo.getUprofile().isEmpty()) {
			uvo.setUprofile("default.png");
		}
		
		int res = uservice.userJoin(uvo);
		System.out.println("res >>> " + res);
		
		if(res > 0){
			rattrs.addFlashAttribute("msg","회원가입이 완료되었습니다. 로그인해주세요.");
			return "redirect:/user/logForm";
		}
		rattrs.addFlashAttribute("msg","회원가입에 실패했습니다. 다시 시도해주세요.");
		return "redirect:/user/form";
	}
	
	//아이디 중복확인
	@RequestMapping(value = "/IdCheck")
	@ResponseBody
	public String IdCheck(@RequestParam String uid) {
		System.out.println("UserController IdCheck() 함수진입 >>> ");
		System.out.println("uid >>> " + uid);
		int res = uservice.IdCheck(uid);
		System.out.println("res >>> " +res);
		return res == 0 ? "available" : "duplicated";
	}
	
	//이메일 중복확인
	@RequestMapping(value = "/mailCheck")
	@ResponseBody
	public String mailCheck(@RequestParam String umail) {
		System.out.println("UserController mailCheck() 함수진입");
		System.out.println("umail >>> " + umail);
		int res = uservice.countByUmail(umail);
		System.out.println("res >>> " + res);
		return res == 0 ? "available" : "duplicated";
	}
	
	//로그인 폼
	@RequestMapping(value = "/logForm")
	public String logForm() {
		System.out.println("UserController logForm() 함수진입 >>> ");
		return "user/logForm";
	}
	
	//로그인 처리
	@PostMapping(value = "/login")
	public String login(@RequestParam String uid,
						@RequestParam String upw,
						HttpSession session,
						RedirectAttributes rattrs) {
		System.out.println("UserController login() 함수진입 >>> ");
		System.out.println("uid >>> " + uid);
		
		UserVO uvo = uservice.selectID(uid);
		System.out.println("uvo >>> " + uvo);
		
		//존재하지 않거나 탈퇴한 회원
		if(uvo == null || uvo.getUdeleteyn() == 'Y') {
			rattrs.addFlashAttribute("msg" , "아이디 또는 비밀번호가 틀렸습니다.");
			return "redirect:/user/logForm";
		}
		//비밀번호 암호화 후 검증
		if(!EncryptUtils.encryptMD5(upw).equals(uvo.getUpw())) {
			rattrs.addFlashAttribute("msg" , "아이디 또는 비밀번호가 틀렸습니다");
			return "redirect:/user/logForm";
		}
		//세션저장
		session.setAttribute("loginUser", uvo);
		System.out.println("로그인 성공 >>> " + uvo.getUid());
		
		//임시버번 상태면 비번 변경페이지로 강제 이동
		if("Y".equals(uvo.getutempyn())) {
			rattrs.addFlashAttribute("msg","임시 비밀번호로 로그인하셨습니다. 비밀번호를 변경해주세요");
			return "redirect:/user/changePwForm";
		}
		return "redirect:/";
	}
	
	//로그아웃
	@RequestMapping(value = "/logout")
	public String logout(HttpSession session) {
		System.out.println("UserController logout() 함수진입 >>> ");
		session.invalidate();
		return "redirect:/";
	}
	
	//마이페이지
	@RequestMapping(value = "/mypage")
	public String mypage(HttpSession session, Model model) {
		System.out.println("UserController mypage() 함수진입 >>> ");
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		UserVO uvo = uservice.userOne(loginUser.getUno());
		System.out.println("uvo >>> " + uvo);
		model.addAttribute("userInfo", uvo);
		return "user/mypage";
	}
	
	//회원정보 수정 폼
	@RequestMapping(value = "/modifyForm")
	public String modifyForm(HttpSession session, Model model) {
		System.out.println("UserController modfyForm() 함수진입 >>> ");
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		UserVO uvo = uservice.userOne(loginUser.getUno());
		System.out.println("uvo >>> " + uvo);
		model.addAttribute("userInfo", uvo);
		return "redirect:/modifyForm";
	}
	
	//회원정보 수정 처리
	@PostMapping(value = "/modify")
	public String modify(@ModelAttribute UserVO uvo,
						HttpSession session,
						RedirectAttributes rattrs) {
		System.out.println("UserController modify()함수진입 >>> ");
		System.out.println("uvo >>> " + uvo);
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		uvo.setUno(loginUser.getUno());
		int res = uservice.userUpdate(uvo);
		System.out.println("res >>> " + res);
		
		//세션 갱신
		session.setAttribute("loginUser" , uservice.userOne(loginUser.getUno()));
		rattrs.addFlashAttribute("msg", "회원정보가 수정되었습니다.");
		return "redirect:/user/mypage";
	}
	//프로필 이미지 업로드
	@PostMapping(value ="/uploadProfile")
	public String uploadProfile(@RequestParam("profileFile") MultipartFile file,
								HttpSession session,
								RedirectAttributes rattrs) {
		System.out.println("UserConrtoller uploadProfile() 함수진입 >>> ");
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		return "";
	}
}
