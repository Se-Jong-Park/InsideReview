<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jeonju.movie.rating.mapper.RatingMapper">

    <!-- 별점 등록 -->
    <insert id="insertRating" parameterType="com.jeonju.movie.rating.vo.RatingVO">
        INSERT INTO RATING (RATNO, MNO, UNO, RATSCORE, RATINSERTDATE)
        VALUES (#{ratno}, #{mno}, #{uno}, #{ratscore}, NOW())
    </insert>

    <!-- maxno 조회 (채번용) -->
    <select id="getMaxNo" resultType="int">
        SELECT IFNULL(MAX(CAST(SUBSTRING(RATNO, 10) AS UNSIGNED)), 0) + 1
        FROM   RATING
        WHERE  SUBSTRING(RATNO, 2, 8) = DATE_FORMAT(NOW(), '%Y%m%d')
    </select>

    <!-- 이미 별점 등록 여부 확인 -->
    <select id="checkRating" parameterType="com.jeonju.movie.rating.vo.RatingVO" resultType="int">
        SELECT COUNT(*)
        FROM   RATING
        WHERE  MNO = #{mno}
          AND  UNO = #{uno}
    </select>

    <!-- 특정 영화 평균 별점 -->
    <select id="getAvgScore" parameterType="String" resultType="double">
        SELECT IFNULL(AVG(CAST(RATSCORE AS DECIMAL)), 0)
        FROM   RATING
        WHERE  MNO = #{mno}
    </select>

    <!-- 별점 TOP 10 영화 (메인화면 랭킹) -->
    <select id="getRankingList" resultType="com.jeonju.movie.movie.vo.MovieVO">
        SELECT M.MNO, M.MTITLE, M.MPOSTER,
               IFNULL(AVG(CAST(R.RATSCORE AS DECIMAL)), 0) AS avgScore,
               COUNT(R.RATNO) AS ratCount
        FROM   MOVIE M
        LEFT JOIN RATING R ON M.MNO = R.MNO
        WHERE  M.MDELETEYN IS NULL
        GROUP BY M.MNO, M.MTITLE, M.MPOSTER
        ORDER BY avgScore DESC, ratCount DESC
        LIMIT 10
    </select>

</mapper>
