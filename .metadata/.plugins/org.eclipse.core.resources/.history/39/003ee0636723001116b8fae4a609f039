<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c"   uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>커뮤니티 — CINEVERSE</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/main.css">
    <style>
        /* ── 페이지 헤더 ── */
        .page-header {
            padding: 100px 48px 48px;
            border-bottom: 1px solid var(--border);
        }
        .page-header-inner {
            max-width: 1200px; margin: 0 auto;
        }
        .page-label {
            font-size: .72rem; font-weight: 700; letter-spacing: 3px;
            color: var(--accent); margin-bottom: 12px;
        }
        .page-title {
            font-family: 'Bebas Neue', cursive;
            font-size: clamp(2rem, 5vw, 3.5rem);
            letter-spacing: 3px; line-height: 1;
            margin-bottom: 12px;
        }
        .page-title span { color: var(--accent); }
        .page-desc {
            font-size: .88rem; color: var(--text-secondary);
        }

        /* ── 영화 그리드 ── */
        .movie-list-wrap {
            max-width: 1200px; margin: 0 auto;
            padding: 48px 48px;
        }
        .movie-list-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 24px;
        }

        /* ── 영화 카드 ── */
        .movie-list-card {
            display: block; text-decoration: none; color: inherit;
            border-radius: 12px; overflow: hidden;
            background: var(--bg-card);
            border: 1px solid var(--border);
            transition: transform .25s, box-shadow .25s, border-color .25s;
            cursor: pointer;
        }
        .movie-list-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 48px rgba(0,0,0,.6);
            border-color: rgba(229,9,20,.3);
        }
        .mlc-poster {
            aspect-ratio: 2/3;
            position: relative; overflow: hidden;
            background: var(--bg-hover);
        }
        .mlc-poster img {
            width: 100%; height: 100%; object-fit: cover;
            transition: transform .4s;
        }
        .movie-list-card:hover .mlc-poster img { transform: scale(1.05); }
        .mlc-poster-ph {
            width: 100%; height: 100%;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center; gap: 8px;
            font-family: 'Bebas Neue', cursive;
            font-size: .9rem; letter-spacing: 2px;
            color: var(--text-muted);
            padding: 16px; text-align: center;
        }
        .mlc-poster-ph .ph-icon {
            font-size: 2.4rem; opacity: .3;
        }

        /* 별점 오버레이 */
        .mlc-score-badge {
            position: absolute; top: 10px; right: 10px;
            background: rgba(10,10,15,.85);
            border: 1px solid rgba(245,197,24,.4);
            color: var(--gold);
            font-family: 'Bebas Neue', cursive;
            font-size: .95rem; letter-spacing: 1px;
            padding: 4px 8px; border-radius: 5px;
        }

        /* 호버 오버레이 */
        .mlc-hover-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,10,15,.95) 0%, transparent 55%);
            opacity: 0; transition: opacity .3s;
            display: flex; align-items: flex-end; padding: 16px;
        }
        .movie-list-card:hover .mlc-hover-overlay { opacity: 1; }
        .mlc-enter-btn {
            width: 100%;
            background: var(--accent); color: #fff;
            border: none; border-radius: 6px; padding: 10px;
            font-size: .82rem; font-weight: 700; letter-spacing: .5px;
            cursor: pointer;
        }

        /* 카드 정보 */
        .mlc-info {
            padding: 14px 16px 16px;
        }
        .mlc-genre {
            font-size: .68rem; font-weight: 700; letter-spacing: 1px;
            color: var(--accent); margin-bottom: 6px;
        }
        .mlc-title {
            font-size: .92rem; font-weight: 700;
            margin-bottom: 6px; line-height: 1.35;
            display: -webkit-box; -webkit-line-clamp: 2;
            -webkit-box-orient: vertical; overflow: hidden;
        }
        .mlc-bottom {
            display: flex; justify-content: space-between; align-items: center;
        }
        .mlc-date { font-size: .72rem; color: var(--text-muted); }
        .mlc-stars { font-size: .75rem; color: var(--gold); }

        /* 빈 목록 */
        .movie-empty {
            grid-column: 1 / -1;
            text-align: center; padding: 100px 0;
            color: var(--text-muted);
        }
        .movie-empty-icon { font-size: 3rem; margin-bottom: 16px; opacity: .3; }
        .movie-empty p { font-size: .88rem; margin-top: 8px; }

        /* ── 반응형 ── */
        @media (max-width: 768px) {
            .page-header { padding: 88px 20px 32px; }
            .movie-list-wrap { padding: 32px 20px; }
            .movie-list-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 16px; }
        }
    </style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
    <a href="${pageContext.request.contextPath}/" class="nav-logo">CINEVERSE</a>
    <div class="nav-links">
        <a href="${pageContext.request.contextPath}/main">홈</a>
        <a href="${pageContext.request.contextPath}/movie/list" class="active">커뮤니티</a>
    </div>
    <div class="nav-right">
        <c:choose>
            <c:when test="${not empty sessionScope.loginUser}">
                <span style="font-size:.82rem; color:var(--text-secondary);">${sessionScope.loginUser.nickname}</span>
                <a href="${pageContext.request.contextPath}/member/logout" class="btn-logout">로그아웃</a>
            </c:when>
            <c:otherwise>
                <a href="${pageContext.request.contextPath}/member/login" class="btn-login">로그인</a>
            </c:otherwise>
        </c:choose>
    </div>
</nav>

<!-- ── 페이지 헤더 ── -->
<div class="page-header">
    <div class="page-header-inner">
        <div class="page-label">COMMUNITY</div>
        <div class="page-title">영화별 <span>커뮤니티</span></div>
        <div class="page-desc">보고 싶은 영화를 선택해서 리뷰와 별점을 남겨보세요</div>
    </div>
</div>

<!-- ── 영화 목록 그리드 ── -->
<div class="movie-list-wrap">
    <div class="movie-list-grid">
        <c:choose>
            <c:when test="${not empty movieList}">
                <c:forEach var="movie" items="${movieList}">
                    <a href="${pageContext.request.contextPath}/board/list?mno=${movie.mno}"
                       class="movie-list-card">
                        <div class="mlc-poster">
                            <c:choose>
                                <c:when test="${not empty movie.mposter && movie.mposter != 'default.png'}">
                                    <img src="${pageContext.request.contextPath}/resources/upload/${movie.mposter}"
                                         alt="${movie.mtitle}" loading="lazy">
                                </c:when>
                                <c:otherwise>
                                    <div class="mlc-poster-ph">
                                        <span class="ph-icon">🎬</span>
                                        ${movie.mtitle}
                                    </div>
                                </c:otherwise>
                            </c:choose>

                            <%-- 별점 배지 --%>
                            <c:if test="${movie.avgScore > 0}">
                                <div class="mlc-score-badge">
                                    ★ <fmt:formatNumber value="${movie.avgScore}" pattern="0.0"/>
                                </div>
                            </c:if>

                            <%-- 호버 오버레이 --%>
                            <div class="mlc-hover-overlay">
                                <button class="mlc-enter-btn">게시판 입장 →</button>
                            </div>
                        </div>

                        <div class="mlc-info">
                            <c:if test="${not empty movie.mgenre}">
                                <div class="mlc-genre">${movie.mgenre}</div>
                            </c:if>
                            <div class="mlc-title">${movie.mtitle}</div>
                            <div class="mlc-bottom">
                                <span class="mlc-date">${movie.mreleasedate}</span>
                                <c:choose>
                                    <c:when test="${movie.avgScore > 0}">
                                        <span class="mlc-stars">
                                            ★ <fmt:formatNumber value="${movie.avgScore}" pattern="0.0"/>
                                        </span>
                                    </c:when>
                                    <c:otherwise>
                                        <span class="mlc-date">별점 없음</span>
                                    </c:otherwise>
                                </c:choose>
                            </div>
                        </div>
                    </a>
                </c:forEach>
            </c:when>
            <c:otherwise>
                <div class="movie-empty">
                    <div class="movie-empty-icon">🎬</div>
                    등록된 영화가 없습니다
                    <p>관리자가 영화를 등록하면 여기에 표시돼요</p>
                </div>
            </c:otherwise>
        </c:choose>
    </div>
</div>

<footer>
    <div class="footer-logo">CINEVERSE</div>
    <div class="footer-copy">© 2025 CINEVERSE. All rights reserved.</div>
</footer>

<script src="${pageContext.request.contextPath}/resources/js/main.js"></script>
</body>
</html>
