	}
	//프로필 이미지 업로드
	@PostMapping(value ="/uploadProfile")
	public String uploadProfile(@RequestParam("profileFile") MultipartFile file,
								HttpSession session,
								RedirectAttributes rattrs) {
		System.out.println("UserConrtoller uploadProfile() 함수진입 >>> ");
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		if(file != null && !file.isEmpty()) {
			try {
				File dir = new File(uploadPath);
				if (!dir.exists()) dir.mkdir();
				
				String original = file.getOriginalFilename();
				String ext = original.substring(original.lastIndexOf("."));
				String saveName = UUID.randomUUID().toString().replace("-", "").substring(0,12) + ext;
				System.out.println("savedName >>> " + saveName);
				
				file.transferTo(new File(uploadPath + File.separator + saveName));
				UserVO uvo = new UserVO();
				uvo.setUno(loginUser.getUno());
				uvo.setUprofile(saveName);
				
				int res = uservice.updateUprofile(uvo);
				System.out.println("res >>> " + res);
				
				//세션갱신
				session.setAttribute("loginUser", uservice.userOne(loginUser.getUno()));
			}catch (Exception e) {
				e.printStackTrace();
			}
		}
		return "redirect:/user/mypage";
	}
	
	//임시 비밀번호 발급 폼
	@RequestMapping(value ="/tempPwForm")
