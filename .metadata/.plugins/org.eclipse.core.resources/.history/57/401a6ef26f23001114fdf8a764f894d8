	//임시 비밀번호 발급 처리
	@PostMapping(value = "/tempPw")
	public String tempPw(@RequestParam String umail, RedirectAttributes rattrs) {
		System.out.println("UserController tempPw() 함수진입 >>> ");
		System.out.println("umail >>> " + umail);
		
		UserVO uvo = uservice.selectUserByUmail(umail);
		System.out.println("uvo >>> " + uvo);
		
		if(uvo == null) {
			rattrs.addFlashAttribute("msg","등록된 이메일이 없습니다.");
			return "redirect:/user/tempPwForm";
		}
		
		//8자리 임시 비밀번호 생성
		String tempPw = UUID.randomUUID().toString().replace("-", "").substring(0,8);
		System.out.println("tempPw >>> " + tempPw);
		
		//DB업데이트
		UserVO updateUvo = new UserVO();
		updateUvo.setUno(uvo.getUno());
		updateUvo.setUpw(EncryptUtils.encryptMD5(tempPw));
		updateUvo.setUtempyn("Y");
		
		int res = uservice.updateUpw(updateUvo);
		System.out.println("res >>> " + res);
		
		//화면에 임시 비밀번호 출력
		rattrs.addFlashAttribute("msg", "임시 비밀번호 : " + tempPw);
		return "redirect:/user/tempPwForm";
	}
	
	//비밀번호 변경 폼
	@RequestMapping(value = "/changePwForm")
	public String changePwForm(HttpSession session) {
		System.out.println("UserController changePwForm() 함수진입 >>> ");
		if(session.getAttribute("loginUser") == null) return "redirect:/user/logForm";
		
		return "user/changePwForm";
	}
	
	//비밀번호 변경 처리
	@PostMapping(value = "/changePw")
	public String changePw(@RequestParam String currentUpw,
							@RequestParam String newUpw,
							HttpSession session,
							RedirectAttributes rattrs) {
		System.out.println("UserController changePw() 함수진입 >>> ");
		UserVO loginUser =(UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		//현재 비밀번호 암호화 후 검증
		UserVO uvo = uservice.userOne(loginUser.getUno());
		if(!EncryptUtils.encryptMD5(currentUpw).equals(uvo.getUpw())) {
			System.out.println("현재 비밀번호 불일치 >>> " );
			rattrs.addFlashAttribute("msg", "현재 비밀번호가 일치하지 않습니다");
			return "redirect:/user/changePwForm";
		}
		//새 비밀번호 암호화 후 업데이트
		UserVO updateUvo = new UserVO();
		updateUvo.setUno(loginUser.getUno());
		updateUvo.setUpw(EncryptUtils.encryptMD5(newUpw));
		updateUvo.setUtempyn("N");
		
		int res = uservice.updateUpw(updateUvo);
		System.out.println("res >>> " + res);
		
		// 세션갱신
		session.setAttribute("loginUser", uservice.userOne(loginUser.getUno()));
		rattrs.addFlashAttribute("msg", "비밀번호가 변경되었습니다.");
		return "redirect:/user/mypage";
	}
	
