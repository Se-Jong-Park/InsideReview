	//회원탈퇴 처리
	@PostMapping(value = "/withdraw")
	public String withdraw(@RequestParam String upw,
							HttpSession session,
							RedirectAttributes rattrs) {
		System.out.println("UserController withdraw() 함수진입 >>> ");
		UserVO loginUser = (UserVO) session.getAttribute("loginUser");
		if(loginUser == null) return "redirect:/user/logForm";
		
		//비밀번호 암호화 후 검증
		UserVO uvo = uservice.userOne(loginUser.getUno());
		if(!EncryptUtils.encryptMD5(upw).equals(uvo.getUpw())) {
			System.out.println("비밀번호 불일치 >>>> ");
			rattrs.addFlashAttribute("msg", "비밀번호가 일치하지 않습니다.");
			return "redirect:/user/withdrawForm";
		}
		int res = uservice.userDelete(loginUser.getUno());
		System.out.println("res >>> " + res);
		
		session.invalidate();
		return "redirect:/";
		
	}
