package com.jeonju.movie.comm;

import java.util.Calendar;

public class Chaebun {
	public static final String USER = "U";
	public static final String BOARD = "B";
	public static final String COMMENT = "C";
	public static final String MOVIE = "M";
	public static final String RATING = "R";
	
	public static String getDate() {
		System.out.println("Chaebun getdate() 함수 진입 =======");
		Calendar cal = Calendar.getInstance();
		String year = String.valueOf(cal.get(Calendar.YEAR));
		String month = String.valueOf(cal.get(Calendar.MONTH)+1);
		String day = String.valueOf(cal.get(Calendar.DAY_OF_MONTH));
		
		if(month.length() == 1) {
			month = "0" + month;
		}
		if(day.length() == 1) {
			day = "0" + day;
		}
		
		String date = year + month + day;
		System.out.println("date >> " + date);
		return date;
	}
	public static String getNo(int maxno) {
		System.out.println("Chaebun getNo() 함수 진입 =======");
		System.out.println("n >> " + maxno);
		String no = String.valueOf(maxno);
		
		if(no.length() == 1) {
			no = "00" + no;
		}else if(no.length() == 2) {
			no = "0" + no;
		}
		
		System.out.println("no >> " + no);
		return no;
	}
	
	//회원번호
	public static String getUno(int maxno) {
		System.out.println("Chaebun getUno() 함수 진입 =======");
		System.out.println("no >> " + maxno);
		
		String uno = Chaebun.USER + Chaebun.getDate() + Chaebun.getNo(maxno);
		System.out.println("uno >> " + uno);
		return uno;
	}
	
	//게시물 번호
	public static String getBno(int maxno) {
		System.out.println("Chaebun getBno() 함수 진입 =======");
		System.out.println("no >> " + maxno);
		
		String bno = Chaebun.BOARD + Chaebun.getDate() + Chaebun.getNo(maxno);
		System.out.println("bno >> " + bno);
		return bno;
	}
	
	//댓글번호
	public static String getCno(int maxno) {
		System.out.println("Chaebun getCno() 함수 진입 =======");
		System.out.println("no >> " + maxno);
		
		String cno = Chaebun.COMMENT + Chaebun.getDate() + Chaebun.getNo(maxno);
		System.out.println("cno >> " + cno);
		return cno;
	}
	
