<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
    <%@ taglib prefix="c"   uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>마이페이지</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<style>
	body{background-color: #141414; color: white;}
	.card{background-color: #1f1f1f; border: none;}
	.table{color: white;}
	.table th{background-color: #2a2a2a; color: #aaa; border-color: #333;}
	.table td{border-color: #333;}
	.btn-netflix{
		background-color: #E50914;
		color: white;
		border: none;
	}
	.btn-netflix:hover {background-color: #b20710; color: white;}
	.btn-outline-netflix{
		background-color: transparent;
		border: 1px solid #E50914;
		color: #50914;
	}
	.btn-outline-gray:hover {background-color: #2a2a2a; color: white;}
	.profile-img{
		width: 90px; height: 90px;
		border-radius: 50%;
		border: 3px solid #E50914;
		object-fit: cover;
	}
	.form-control{
		background-color: #2a2a2a;
		border: 1px solid #444;
		color: white;
	}
	a{color: #E50914; text-decoration: none;}
</style>
</head>
<body>
<div class="container py-5">
	<div class="row justify-content-center">
		<div class="col-md-7">
			<div class="card shadow p-4">
				<h4 class="text-center mb-4">마이페이지</h4>
				
				<!-- 임시비밀번호 경고 -->
				<c:if test="${userInfo.utempyn == 'Y'}">
					<div class="alert alert-warning">
						임시 비밀번호를 사용 중입니다. 반드시 비밀번호를 변경해주세요.
					</div>
				</c:if>
				<c:if test="${not empty msg}">
					<div class="alert alert-success">${msg}</div>
				</c:if>
				<!-- 프로필 이미지 -->
				<div class="text-center mb-4">
					<img src="/upload/profile/${userInfo.uprofile}">
					alt="프로필 이미지"
					class"profile-img"
					onerror="this.src='/resources/img/default.png'"
				</div>
			</div>
		</div>
	</div>

</div>
</body>
</html>