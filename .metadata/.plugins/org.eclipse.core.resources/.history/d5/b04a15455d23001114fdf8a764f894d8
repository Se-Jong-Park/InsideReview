<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c"   uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>마이페이지</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #141414; color: white; }
        .card { background-color: #1f1f1f; border: none; }
        .table { color: white; }
        .table th { background-color: #2a2a2a; color: #aaa; border-color: #333; }
        .table td { border-color: #333; }
        .btn-netflix {
            background-color: #E50914;
            color: white;
            border: none;
        }
        .btn-netflix:hover { background-color: #b20710; color: white; }
        .btn-outline-netflix {
            background-color: transparent;
            border: 1px solid #E50914;
            color: #E50914;
        }
        .btn-outline-netflix:hover { background-color: #E50914; color: white; }
        .btn-outline-gray {
            background-color: transparent;
            border: 1px solid #444;
            color: #aaa;
        }
        .btn-outline-gray:hover { background-color: #2a2a2a; color: white; }
        .profile-img {
            width: 90px; height: 90px;
            border-radius: 50%;
            border: 3px solid #E50914;
            object-fit: cover;
        }
        .form-control {
            background-color: #2a2a2a;
            border: 1px solid #444;
            color: white;
        }
        a { color: #E50914; text-decoration: none; }
    </style>
</head>
<body>
 
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow p-4">
                <h4 class="text-center mb-4">마이페이지</h4>
 
                <!-- 임시비번 경고 -->
                <c:if test="${userInfo.utempyn == 'Y'}">
                    <div class="alert alert-warning">
                        임시 비밀번호를 사용 중입니다. 반드시 비밀번호를 변경해주세요.
                    </div>
                </c:if>
 
                <c:if test="${not empty msg}">
                    <div class="alert alert-success">${msg}</div>
                </c:if>
 
                <!-- 프로필 이미지 -->
                <div class="text-center mb-4">
                    <img src="${pageContext.request.contextPath}/upload/profile/${userInfo.uprofile}"
                         alt="프로필 이미지"
                         class="profile-img"
                         onerror="this.src='/resources/img/default.png'">
                    <div class="mt-2">
                        <form action="/user/uploadProfile" method="post" enctype="multipart/form-data" class="d-inline">
                            <input type="file" name="profileFile" accept="image/*" class="form-control form-control-sm d-inline w-auto">
                            <button type="submit" class="btn btn-sm btn-outline-gray">이미지 변경</button>
                        </form>
                    </div>
                </div>
 
                <!-- 회원 정보 -->
                <table class="table table-bordered">
                    <tr><th width="30%">회원번호</th><td>${userInfo.uno}</td></tr>
                    <tr><th>아이디</th><td>${userInfo.uid}</td></tr>
                    <tr><th>이름</th><td>${userInfo.uname}</td></tr>
                    <tr><th>이메일</th><td>${userInfo.umail}</td></tr>
                    <tr><th>전화번호</th><td>${userInfo.uphone}</td></tr>
                    <tr><th>생년월일</th>
                        <td><fmt:formatDate value="${userInfo.ubirth}" pattern="yyyy-MM-dd"/></td></tr>
                    <tr><th>성별</th>
                        <td>
                            <c:choose>
                                <c:when test='${userInfo.ugender == "M"}'>남성</c:when>
                                <c:when test='${userInfo.ugender == "F"}'>여성</c:when>
                                <c:otherwise>-</c:otherwise>
                            </c:choose>
                        </td></tr>
                    <tr><th>주소</th><td>${userInfo.uaddr}</td></tr>
                    <tr><th>권한</th>
                        <td>${userInfo.urole == "A" ? '관리자' : '일반회원'}</td></tr>
                    <tr><th>가입일</th>
                        <td><fmt:formatDate value="${userInfo.uinsertdate}" pattern="yyyy-MM-dd"/></td></tr>
                </table>
 
                <!-- 버튼 -->
                <div class="d-flex justify-content-between mt-3">
                    <div>
                        <a href="/user/modifyForm" class="btn btn-outline-netflix me-2">정보 수정</a>
                        <a href="/user/changePwForm" class="btn btn-outline-gray">비밀번호 변경</a>
                    </div>
                    <div>
                        <a href="/user/withdrawForm" class="btn btn-outline-gray me-2">회원탈퇴</a>
                        <a href="/user/logout" class="btn btn-outline-gray">로그아웃</a>
                    </div>
                </div>
 
            </div>
        </div>
    </div>
</div>
 
</body>
</html>