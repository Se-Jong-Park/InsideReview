/* ============================================================
   CINEVERSE — main.css
   경로: /resources/css/main.css
   ============================================================ */

:root {
    --bg-deep:    #0a0a0f;
    --bg-card:    #13131a;
    --bg-hover:   #1e1e2a;
    --accent:     #e50914;
    --accent-dim: #8b0000;
    --gold:       #f5c518;
    --text-primary:   #f0f0f0;
    --text-secondary: #9090a0;
    --text-muted:     #505060;
    --border:     rgba(255,255,255,0.07);
    --radius:     10px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    background: var(--bg-deep);
    color: var(--text-primary);
    font-family: 'Noto Sans KR', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
}

/* ── NAV ── */
nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: linear-gradient(to bottom, rgba(10,10,15,.95), transparent);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border);
}
.nav-logo {
    font-family: 'Bebas Neue', cursive;
    font-size: 2rem;
    letter-spacing: 4px;
    color: var(--accent);
    text-decoration: none;
}
.nav-links { display: flex; gap: 28px; }
.nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: .85rem;
    font-weight: 500;
    letter-spacing: .5px;
    transition: color .2s;
}
.nav-links a:hover, .nav-links a.active { color: var(--text-primary); }
.nav-right { display: flex; align-items: center; gap: 16px; }
.nav-search-btn {
    background: none; border: none; cursor: pointer;
    color: var(--text-secondary); font-size: 1.1rem; padding: 4px;
    transition: color .2s;
}
.nav-search-btn:hover { color: var(--text-primary); }
.btn-login {
    padding: 7px 20px;
    background: var(--accent);
    color: #fff; border: none; border-radius: 4px;
    font-size: .82rem; font-weight: 700; cursor: pointer;
    letter-spacing: .5px; transition: background .2s;
    text-decoration: none;
}
.btn-login:hover { background: #c40812; }
.btn-logout {
    padding: 7px 20px;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 4px;
    font-size: .82rem; font-weight: 500; cursor: pointer;
    text-decoration: none; transition: border-color .2s;
}
.btn-logout:hover { border-color: rgba(255,255,255,.5); color: var(--text-primary); }

/* ── HERO SLIDER ── */
.hero {
    position: relative;
    height: 88vh; min-height: 560px;
    overflow: hidden;
}
.hero-slides { display: flex; height: 100%; transition: transform .7s cubic-bezier(.4,0,.2,1); }
.hero-slide {
    min-width: 100%;
    position: relative;
    background-size: cover;
    background-position: center top;
}
.hero-slide:nth-child(1) { background: linear-gradient(135deg, #1a0a2e 0%, #16213e 40%, #0f3460 100%); }
.hero-slide:nth-child(2) { background: linear-gradient(135deg, #1a0000 0%, #3d0000 40%, #7b1e00 100%); }
.hero-slide:nth-child(3) { background: linear-gradient(135deg, #001a10 0%, #003320 40%, #005a35 100%); }

.hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(10,10,15,.92) 0%, rgba(10,10,15,.5) 55%, transparent 100%);
}
.hero-content {
    position: absolute; bottom: 15%; left: 7%;
    max-width: 480px;
    animation: fadeUp .6s ease both;
}
@keyframes fadeUp {
    from { opacity:0; transform:translateY(24px); }
    to   { opacity:1; transform:translateY(0); }
}
.hero-badge {
    display: inline-block;
    background: var(--accent); color: #fff;
    font-size: .7rem; font-weight: 700; letter-spacing: 2px;
    padding: 4px 10px; border-radius: 3px; margin-bottom: 14px;
}
.hero-title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05; letter-spacing: 2px;
    margin-bottom: 12px;
    text-shadow: 0 2px 20px rgba(0,0,0,.6);
}
.hero-meta {
    display: flex; gap: 14px; align-items: center;
    font-size: .8rem; color: var(--text-secondary);
    margin-bottom: 16px;
}
.hero-rating { color: var(--gold); font-weight: 700; }
.hero-desc {
    font-size: .88rem; line-height: 1.7;
    color: var(--text-secondary); margin-bottom: 24px;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
}
.hero-actions { display: flex; gap: 12px; }
.btn-primary {
    padding: 11px 28px;
    background: var(--accent); color: #fff;
    border: none; border-radius: 5px;
    font-size: .88rem; font-weight: 700; cursor: pointer;
    transition: background .2s, transform .15s;
    text-decoration: none; display: inline-block;
}
.btn-primary:hover { background: #c40812; transform: translateY(-1px); }
.btn-secondary {
    padding: 11px 28px;
    background: rgba(255,255,255,.1); color: var(--text-primary);
    border: 1px solid rgba(255,255,255,.2); border-radius: 5px;
    font-size: .88rem; font-weight: 500; cursor: pointer;
    transition: background .2s;
    text-decoration: none; display: inline-block;
}
.btn-secondary:hover { background: rgba(255,255,255,.18); }

.hero-dots {
    position: absolute; bottom: 28px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px;
}
.dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(255,255,255,.3); cursor: pointer;
    transition: all .3s;
}
.dot.active { background: var(--accent); width: 22px; border-radius: 3px; }

.hero-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(0,0,0,.5); border: 1px solid var(--border);
    color: #fff; width: 44px; height: 44px; border-radius: 50%;
    font-size: 1.1rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    transition: background .2s; z-index: 10;
}
.hero-arrow:hover { background: var(--accent); }
.hero-arrow.left  { left: 28px; }
.hero-arrow.right { right: 28px; }

/* ── SEARCH BAR ── */
.search-wrap {
    position: relative; z-index: 10;
    margin-top: -32px;
    display: flex; justify-content: center;
    padding: 0 24px;
}
.search-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 50px;
    display: flex; align-items: center;
    width: 100%; max-width: 620px;
    padding: 0 24px;
    box-shadow: 0 8px 40px rgba(0,0,0,.5);
    transition: border-color .2s;
}
.search-box:focus-within { border-color: var(--accent); }
.search-icon { color: var(--text-muted); margin-right: 12px; font-size: 1rem; }
.search-box input {
    flex: 1; background: none; border: none; outline: none;
    color: var(--text-primary); font-size: .92rem;
    padding: 16px 0; font-family: inherit;
}
.search-box input::placeholder { color: var(--text-muted); }
.search-btn {
    background: var(--accent); border: none; color: #fff;
    padding: 8px 20px; border-radius: 50px; font-size: .82rem;
    font-weight: 700; cursor: pointer; letter-spacing: .5px;
    transition: background .2s;
}
.search-btn:hover { background: #c40812; }

/* ── SECTION 공통 ── */
.section { padding: 56px 48px 16px; }
.section-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 24px;
}
.section-title {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.6rem; letter-spacing: 2px;
}
.section-title span { color: var(--accent); }
.section-more {
    font-size: .78rem; color: var(--text-secondary);
    text-decoration: none; letter-spacing: .5px;
    border-bottom: 1px solid var(--text-muted);
    padding-bottom: 1px; transition: color .2s;
}
.section-more:hover { color: var(--text-primary); }

/* ── 영화 카드 그리드 ── */
.movies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 18px;
}
.movie-card {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
    cursor: pointer;
    transition: transform .25s, box-shadow .25s;
    text-decoration: none; color: inherit;
    display: block;
}
.movie-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 16px 40px rgba(0,0,0,.6);
}
.movie-poster {
    aspect-ratio: 2/3;
    background: var(--bg-hover);
    position: relative; overflow: hidden;
}
.movie-poster img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .4s;
}
.movie-card:hover .movie-poster img { transform: scale(1.05); }
.poster-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', cursive;
    font-size: 1.1rem; letter-spacing: 2px;
    color: var(--text-muted);
}
.poster-ph-1 { background: linear-gradient(160deg, #1a1030, #0d0820); }
.poster-ph-2 { background: linear-gradient(160deg, #201010, #100808); }
.poster-ph-3 { background: linear-gradient(160deg, #101820, #080f18); }
.poster-ph-4 { background: linear-gradient(160deg, #102018, #081410); }
.poster-ph-5 { background: linear-gradient(160deg, #201808, #140f04); }
.poster-ph-6 { background: linear-gradient(160deg, #181018, #100810); }

.movie-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(10,10,15,.9) 0%, transparent 50%);
    opacity: 0; transition: opacity .3s;
    display: flex; align-items: flex-end; padding: 12px;
}
.movie-card:hover .movie-overlay { opacity: 1; }
.overlay-btn {
    width: 100%;
    background: var(--accent); color: #fff;
    border: none; border-radius: 5px; padding: 8px;
    font-size: .8rem; font-weight: 700; cursor: pointer;
    letter-spacing: .5px;
}
.movie-info { padding: 10px 12px 14px; }
.movie-title {
    font-size: .85rem; font-weight: 700;
    margin-bottom: 5px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.movie-meta-row {
    display: flex; justify-content: space-between; align-items: center;
}
.movie-year { font-size: .75rem; color: var(--text-muted); }
.movie-stars {
    font-size: .75rem; color: var(--gold);
    display: flex; align-items: center; gap: 3px;
}

/* ── 인기 랭킹 (가로 스크롤) ── */
.rank-scroll {
    display: flex; gap: 16px;
    overflow-x: auto; padding-bottom: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--text-muted) transparent;
}
.rank-scroll::-webkit-scrollbar { height: 4px; }
.rank-scroll::-webkit-scrollbar-track { background: transparent; }
.rank-scroll::-webkit-scrollbar-thumb { background: var(--text-muted); border-radius: 2px; }
.rank-card {
    min-width: 130px; flex-shrink: 0;
    position: relative; cursor: pointer;
    transition: transform .25s;
    text-decoration: none; color: inherit;
}
.rank-card:hover { transform: translateY(-4px); }
.rank-num {
    font-family: 'Bebas Neue', cursive;
    font-size: 4rem; line-height: 1;
    color: var(--bg-hover);
    -webkit-text-stroke: 1px var(--text-muted);
    position: absolute; bottom: 36px; left: -8px;
    z-index: 1;
}
.rank-poster {
    width: calc(100% - 16px);
    aspect-ratio: 2/3;
    border-radius: 8px; overflow: hidden;
    margin-left: 16px;
    position: relative; z-index: 2;
}
.rank-poster img { width: 100%; height: 100%; object-fit: cover; }
.rank-title {
    font-size: .78rem; font-weight: 600;
    margin-top: 6px; padding-left: 16px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}

/* ── 최신 게시물 ── */
.post-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 14px 16px;
    background: var(--bg-card);
    border-radius: var(--radius);
    margin-bottom: 6px;
    transition: background .2s;
    cursor: pointer;
    text-decoration: none; color: inherit;
}
.post-item:hover { background: var(--bg-hover); }
.post-movie-tag {
    display: inline-block;
    font-size: .68rem; font-weight: 700; letter-spacing: .5px;
    color: var(--accent); background: rgba(229,9,20,.1);
    border: 1px solid rgba(229,9,20,.25);
    padding: 2px 8px; border-radius: 3px; margin-bottom: 5px;
}
.post-title { font-size: .88rem; font-weight: 500; }
.post-right { text-align: right; }
.post-author { font-size: .75rem; color: var(--text-secondary); margin-bottom: 4px; }
.post-date   { font-size: .72rem; color: var(--text-muted); }

/* ── FOOTER ── */
footer {
    margin-top: 60px;
    padding: 32px 48px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
}
.footer-logo {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.4rem; letter-spacing: 3px; color: var(--text-muted);
}
.footer-copy { font-size: .75rem; color: var(--text-muted); }

/* ── 반응형 ── */
@media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .section { padding: 40px 20px 12px; }
    footer { padding: 24px 20px; flex-direction: column; gap: 8px; }
    .hero-content { left: 5%; max-width: 90%; }
    .movies-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 12px; }
}
