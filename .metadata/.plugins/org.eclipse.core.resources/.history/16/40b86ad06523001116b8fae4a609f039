/* ============================================================
   CINEVERSE — main.css (파스텔 감성 테마)
   경로: /resources/css/main.css
   ============================================================ */

@import url('https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap');

:root {
    --bg-deep:    #fdf6f0;
    --bg-card:    #ffffff;
    --bg-hover:   #fef0e8;
    --accent:     #e8735a;
    --accent-dim: #f0a090;
    --gold:       #e8a045;
    --text-primary:   #2d2320;
    --text-secondary: #7a6560;
    --text-muted:     #b5a8a3;
    --border:     rgba(180,140,120,0.15);
    --radius:     12px;
    --shadow:     0 4px 24px rgba(180,100,70,.08);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    background: var(--bg-deep);
    color: var(--text-primary);
    font-family: 'Noto Sans KR', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
}

/* ── NAV ── */
nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(253,246,240,.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
}
.nav-logo {
    font-family: 'Gowun Batang', serif;
    font-size: 1.5rem;
    letter-spacing: 6px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 700;
}
.nav-links { display: flex; gap: 28px; }
.nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: .85rem;
    font-weight: 500;
    letter-spacing: .5px;
    transition: color .2s;
    position: relative;
    padding-bottom: 2px;
}
.nav-links a::after {
    content: '';
    position: absolute; bottom: -2px; left: 0; right: 0;
    height: 1.5px; background: var(--accent);
    transform: scaleX(0); transition: transform .25s;
}
.nav-links a:hover::after, .nav-links a.active::after { transform: scaleX(1); }
.nav-links a:hover, .nav-links a.active { color: var(--accent); }
.nav-right { display: flex; align-items: center; gap: 16px; }
.nav-search-btn {
    background: none; border: none; cursor: pointer;
    color: var(--text-secondary); font-size: 1.1rem; padding: 4px;
    transition: color .2s;
}
.nav-search-btn:hover { color: var(--accent); }
.btn-login {
    padding: 7px 20px;
    background: var(--accent);
    color: #fff; border: none; border-radius: 50px;
    font-size: .82rem; font-weight: 700; cursor: pointer;
    letter-spacing: .5px; transition: background .2s, transform .15s;
    text-decoration: none;
}
.btn-login:hover { background: #d4614a; transform: translateY(-1px); }
.btn-logout {
    padding: 7px 20px;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    border-radius: 50px;
    font-size: .82rem; cursor: pointer;
    text-decoration: none; transition: all .2s;
}
.btn-logout:hover { border-color: var(--accent); color: var(--accent); }

/* ── HERO SLIDER ── */
.hero {
    position: relative;
    height: 88vh; min-height: 560px;
    overflow: hidden;
}
.hero-slides { display: flex; height: 100%; transition: transform .7s cubic-bezier(.4,0,.2,1); }
.hero-slide {
    min-width: 100%;
    position: relative;
    background-size: cover;
    background-position: center top;
}
.hero-slide:nth-child(1) { background: linear-gradient(135deg, #fde8e0 0%, #fcd5c8 40%, #f8bfb0 100%); }
.hero-slide:nth-child(2) { background: linear-gradient(135deg, #e8f0fe 0%, #d5e4fc 40%, #c0d4f8 100%); }
.hero-slide:nth-child(3) { background: linear-gradient(135deg, #e8fdf0 0%, #d0f5e0 40%, #b8eece 100%); }

.hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to right, rgba(253,246,240,.88) 0%, rgba(253,246,240,.5) 55%, transparent 100%);
}
.hero-content {
    position: absolute; bottom: 15%; left: 7%;
    max-width: 480px;
    animation: fadeUp .6s ease both;
}
@keyframes fadeUp {
    from { opacity:0; transform:translateY(24px); }
    to   { opacity:1; transform:translateY(0); }
}
.hero-badge {
    display: inline-block;
    background: var(--accent); color: #fff;
    font-size: .7rem; font-weight: 700; letter-spacing: 2px;
    padding: 5px 12px; border-radius: 50px; margin-bottom: 14px;
}
.hero-title {
    font-family: 'Gowun Batang', serif;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.1; letter-spacing: 1px;
    margin-bottom: 12px;
    color: var(--text-primary);
}
.hero-meta {
    display: flex; gap: 14px; align-items: center;
    font-size: .8rem; color: var(--text-secondary);
    margin-bottom: 16px;
}
.hero-rating { color: var(--gold); font-weight: 700; }
.hero-desc {
    font-size: .88rem; line-height: 1.8;
    color: var(--text-secondary); margin-bottom: 24px;
    display: -webkit-box; -webkit-line-clamp: 3;
    -webkit-box-orient: vertical; overflow: hidden;
}
.hero-actions { display: flex; gap: 12px; }
.btn-primary {
    padding: 11px 28px;
    background: var(--accent); color: #fff;
    border: none; border-radius: 50px;
    font-size: .88rem; font-weight: 700; cursor: pointer;
    transition: background .2s, transform .15s;
    text-decoration: none; display: inline-block;
    box-shadow: 0 4px 16px rgba(232,115,90,.3);
}
.btn-primary:hover { background: #d4614a; transform: translateY(-2px); }
.btn-secondary {
    padding: 11px 28px;
    background: rgba(255,255,255,.8); color: var(--text-primary);
    border: 1px solid var(--border); border-radius: 50px;
    font-size: .88rem; font-weight: 500; cursor: pointer;
    transition: background .2s;
    text-decoration: none; display: inline-block;
}
.btn-secondary:hover { background: #fff; }

.hero-dots {
    position: absolute; bottom: 48px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 8px;
}
.dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: rgba(180,100,70,.25); cursor: pointer;
    transition: all .3s;
}
.dot.active { background: var(--accent); width: 22px; border-radius: 3px; }

.hero-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: rgba(255,255,255,.8); border: 1px solid var(--border);
    color: var(--text-secondary); width: 44px; height: 44px; border-radius: 50%;
    font-size: 1.1rem; cursor: pointer; display: flex;
    align-items: center; justify-content: center;
    transition: all .2s; z-index: 10;
}
.hero-arrow:hover { background: var(--accent); color: #fff; border-color: var(--accent); }
.hero-arrow.left  { left: 28px; }
.hero-arrow.right { right: 28px; }

/* ── SEARCH BAR ── */
.search-wrap {
    position: relative; z-index: 10;
    margin-top: 20px;
    display: flex; justify-content: center;
    padding: 0 24px;
}
.search-box {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 50px;
    display: flex; align-items: center;
    width: 100%; max-width: 620px;
    padding: 0 24px;
    box-shadow: var(--shadow);
    transition: border-color .2s, box-shadow .2s;
}
.search-box:focus-within {
    border-color: var(--accent);
    box-shadow: 0 4px 24px rgba(232,115,90,.15);
}
.search-icon { color: var(--text-muted); margin-right: 12px; font-size: 1rem; }
.search-box input {
    flex: 1; background: none; border: none; outline: none;
    color: var(--text-primary); font-size: .92rem;
    padding: 16px 0; font-family: inherit;
}
.search-box input::placeholder { color: var(--text-muted); }
.search-btn {
    background: var(--accent); border: none; color: #fff;
    padding: 8px 20px; border-radius: 50px; font-size: .82rem;
    font-weight: 700; cursor: pointer; letter-spacing: .5px;
    transition: background .2s;
}
.search-btn:hover { background: #d4614a; }

/* ── SECTION 공통 ── */
.section { padding: 56px 48px 16px; }
.section-header {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 24px;
}
.section-title {
    font-family: 'Gowun Batang', serif;
    font-size: 1.5rem; letter-spacing: 1px;
    color: var(--text-primary);
}
.section-title span { color: var(--accent); }
.section-more {
    font-size: .78rem; color: var(--text-muted);
    text-decoration: none; letter-spacing: .5px;
    transition: color .2s;
}
.section-more:hover { color: var(--accent); }

/* ── 영화 카드 그리드 ── */
.movies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 20px;
}
.movie-card {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-card);
    cursor: pointer;
    transition: transform .25s, box-shadow .25s;
    text-decoration: none; color: inherit;
    display: block;
    box-shadow: var(--shadow);
    border: 1px solid var(--border);
}
.movie-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(180,100,70,.15);
}
.movie-poster {
    aspect-ratio: 2/3;
    background: var(--bg-hover);
    position: relative; overflow: hidden;
}
.movie-poster img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform .4s;
}
.movie-card:hover .movie-poster img { transform: scale(1.05); }
.poster-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Gowun Batang', serif;
    font-size: 1rem; letter-spacing: 2px;
    color: var(--text-muted);
}
.poster-ph-1 { background: linear-gradient(160deg, #fde8e0, #f8d0c4); }
.poster-ph-2 { background: linear-gradient(160deg, #e8f0fe, #d5e4fc); }
.poster-ph-3 { background: linear-gradient(160deg, #e8fdf0, #d0f5e0); }
.poster-ph-4 { background: linear-gradient(160deg, #fef9e0, #fdf0c0); }
.poster-ph-5 { background: linear-gradient(160deg, #f5e8fe, #ecd5fc); }
.poster-ph-6 { background: linear-gradient(160deg, #fee8f0, #fcd5e4); }

.movie-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(45,35,32,.85) 0%, transparent 55%);
    opacity: 0; transition: opacity .3s;
    display: flex; align-items: flex-end; padding: 12px;
}
.movie-card:hover .movie-overlay { opacity: 1; }
.overlay-btn {
    width: 100%;
    background: var(--accent); color: #fff;
    border: none; border-radius: 50px; padding: 8px;
    font-size: .8rem; font-weight: 700; cursor: pointer;
}
.movie-info { padding: 10px 14px 14px; }
.movie-title {
    font-size: .88rem; font-weight: 700;
    margin-bottom: 5px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    color: var(--text-primary);
}
.movie-meta-row {
    display: flex; justify-content: space-between; align-items: center;
}
.movie-year { font-size: .75rem; color: var(--text-muted); }
.movie-stars {
    font-size: .75rem; color: var(--gold);
    display: flex; align-items: center; gap: 3px;
}

/* ── 인기 랭킹 ── */
.rank-scroll {
    display: flex; gap: 16px;
    overflow-x: auto; padding-bottom: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--text-muted) transparent;
}
.rank-scroll::-webkit-scrollbar { height: 4px; }
.rank-scroll::-webkit-scrollbar-track { background: transparent; }
.rank-scroll::-webkit-scrollbar-thumb { background: var(--accent-dim); border-radius: 2px; }
.rank-card {
    min-width: 130px; flex-shrink: 0;
    position: relative; cursor: pointer;
    transition: transform .25s;
    text-decoration: none; color: inherit;
}
.rank-card:hover { transform: translateY(-4px); }
.rank-num {
    font-family: 'Gowun Batang', serif;
    font-size: 4rem; line-height: 1;
    color: var(--bg-deep);
    -webkit-text-stroke: 1.5px var(--accent-dim);
    position: absolute; bottom: 36px; left: -8px;
    z-index: 1;
}
.rank-poster {
    width: calc(100% - 16px);
    aspect-ratio: 2/3;
    border-radius: 10px; overflow: hidden;
    margin-left: 16px;
    position: relative; z-index: 2;
    box-shadow: var(--shadow);
}
.rank-poster img { width: 100%; height: 100%; object-fit: cover; }
.rank-title {
    font-size: .78rem; font-weight: 600;
    margin-top: 6px; padding-left: 16px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    color: var(--text-primary);
}

/* ── 최신 게시물 ── */
.post-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 14px 18px;
    background: var(--bg-card);
    border-radius: var(--radius);
    margin-bottom: 8px;
    transition: all .2s;
    cursor: pointer;
    text-decoration: none; color: inherit;
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
}
.post-item:hover {
    background: var(--bg-hover);
    border-color: var(--accent-dim);
    transform: translateX(4px);
}
.post-movie-tag {
    display: inline-block;
    font-size: .68rem; font-weight: 700; letter-spacing: .5px;
    color: var(--accent); background: rgba(232,115,90,.08);
    border: 1px solid rgba(232,115,90,.2);
    padding: 2px 8px; border-radius: 50px; margin-bottom: 5px;
}
.post-title { font-size: .88rem; font-weight: 500; color: var(--text-primary); }
.post-right { text-align: right; }
.post-author { font-size: .75rem; color: var(--text-secondary); margin-bottom: 4px; }
.post-date   { font-size: .72rem; color: var(--text-muted); }

/* ── FOOTER ── */
footer {
    margin-top: 60px;
    padding: 32px 48px;
    border-top: 1px solid var(--border);
    display: flex; justify-content: space-between; align-items: center;
    background: #fff;
}
.footer-logo {
    font-family: 'Gowun Batang', serif;
    font-size: 1.2rem; letter-spacing: 4px; color: var(--text-muted);
}
.footer-copy { font-size: .75rem; color: var(--text-muted); }

/* ── 반응형 ── */
@media (max-width: 768px) {
    nav { padding: 0 20px; }
    .nav-links { display: none; }
    .section { padding: 40px 20px 12px; }
    footer { padding: 24px 20px; flex-direction: column; gap: 8px; }
    .hero-content { left: 5%; max-width: 90%; }
    .movies-grid { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 14px; }
}
