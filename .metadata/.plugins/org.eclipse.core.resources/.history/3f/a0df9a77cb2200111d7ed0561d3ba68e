<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jeonju.movie.app.mapper.UserMapper">

 erType="java.lang.String" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM USER WHERE UMAIL = #{umail}
    </select>
 
    <!-- 5. 로그인용 아이디로 조회 (Y=정상회원) -->
    <select id="selectID" parameterType="java.lang.String" resultType="UserVO">
        SELECT * FROM USER
        WHERE UDELETEYN = 'Y'
          AND UID = #{uid}
    </select>
 
    <!-- 6. 이메일로 회원 조회 (임시비번 발급) -->
    <select id="selectUserByUmail" parameterType="java.lang.String" resultType="UserVO">
        SELECT * FROM USER
        WHERE UDELETEYN = 'Y'
          AND UMAIL = #{umail}
    </select>
 
    <!-- 7. 회원번호로 상세 조회 (마이페이지) -->
    <select id="userOne" parameterType="java.lang.String" resultType="UserVO">
        SELECT * FROM USER WHERE UNO = #{uno}
    </select>
 
    <!-- 8. 전체 회원 목록 (관리자) -->
    <select id="userList" parameterType="com.jeonju.movie.comm.SearchCondition" resultType="UserVO">
        SELECT UNO, UNAME, UID, UBIRTH, UPHONE, UPROFILE, UINSERTDATE
        FROM USER
        WHERE UDELETEYN = 'Y'
        <include refid="searchCondition"/>
        ORDER BY UINSERTDATE ASC, UNAME DESC
        LIMIT #{offset}, #{pageSize}
    </select>
 
    <!-- 9. 전체 회원수 -->
    <select id="userCnt" parameterType="com.jeonju.movie.comm.SearchCondition" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM USER
        WHERE UDELETEYN = 'Y'
        <include refid="searchCondition"/>
    </select>
 
    <!-- 검색 조건 -->
    <sql id="searchCondition">
        <choose>
            <when test='option == "NA"'>
                AND UNAME LIKE CONCAT('%', #{keyword}, '%')
            </when>
            <when test='option == "ID"'>
                AND UID LIKE CONCAT('%', #{keyword}, '%')
            </when>
        </choose>
    </sql>
 
    <!-- 10. 아이디 찾기 -->
    <select id="searchID" parameterType="UserVO" resultType="java.lang.String">
        SELECT UID FROM USER
        WHERE UDELETEYN = 'Y'
          AND UNAME  = #{uname}
          AND UPHONE = #{uphone}
    </select>
 
    <!-- 11. 비밀번호 찾기 -->
    <select id="searchPW" parameterType="UserVO" resultType="java.lang.String">
        SELECT UID FROM USER
        WHERE UDELETEYN = 'Y'
          AND UNAME  = #{uname}
          AND UID    = #{uid}
          AND UPHONE = #{uphone}
    </select>
 
    <!-- 12. 회원정보 수정 -->
    <update id="userUpdate" parameterType="UserVO">
        UPDATE USER SET
            UNAME       = #{uname},
            UBIRTH      = #{ubirth},
            UADDR       = #{uaddr},
            UGENDER     = #{ugender},
            UPHONE      = #{uphone},
            UMAIL       = #{umail},
            UUPDATEDATE = NOW()
        WHERE UNO = #{uno}
    </update>
 
    <!-- 13. 프로필 이미지 수정 -->
    <update id="updateUprofile" parameterType="UserVO">
        UPDATE USER SET
            UPROFILE    = #{uprofile},
            UUPDATEDATE = NOW()
        WHERE UNO = #{uno}
    </update>
 
    <!-- 14. 비밀번호 변경 (임시비번: UTEMPYN=Y / 직접변경: UTEMPYN=N) -->
    <update id="updateUpw" parameterType="UserVO">
        UPDATE USER SET
            UPW         = #{upw},
            UTEMPYN     = #{utempyn},
            UUPDATEDATE = NOW()
        WHERE UNO = #{uno}
    </update>
 
    <!-- 15. 회원탈퇴 (소프트 딜리트: UDELETEYN=N) -->
    <update id="userDelete" parameterType="java.lang.String">
        UPDATE USER SET
            UDELETEYN   = 'N',
            UUPDATEDATE = NOW()
        WHERE UNO = #{uno}
    </update>
 
</mapper>