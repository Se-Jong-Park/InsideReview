package com.jeonju.movie.Board.service;

import java.util.List;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import com.jeonju.movie.board.dao.BoardDAO;
import com.jeonju.movie.board.vo.BoardVO;
import com.jeonju.movie.comm.Chaebun;

@Service
public class BoardServiceImpl implements BoardService {

    @Autowired
    private BoardDAO boardDAO;

    @Override
    public List<BoardVO> getBoardList(String mno) {
        return boardDAO.getBoardList(mno);
    }

    @Override
    public List<BoardVO> getRecentBoardList() {
        return boardDAO.getRecentBoardList();
    }

    @Override
    public BoardVO getBoardDetail(String bno) {
        boardDAO.updateBcnt(bno);           // 조회수 +1
        return boardDAO.getBoardDetail(bno);
    }

    @Override
    public void insertBoard(BoardVO vo) {
        int maxno = boardDAO.getMaxNo();
        vo.setBno(Chaebun.getBno(maxno));   // 채번: B20250313001
        boardDAO.insertBoard(vo);
    }

    @Override
    public void updateBoard(BoardVO vo) {
        boardDAO.updateBoard(vo);
    }

    @Override
    public void deleteBoard(String bno) {
        boardDAO.deleteBoard(bno);
    }
}
