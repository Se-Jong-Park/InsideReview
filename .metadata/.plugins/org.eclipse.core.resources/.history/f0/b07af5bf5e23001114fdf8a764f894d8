package com.jeonju.movie.user.vo;

import java.util.Date;

import org.springframework.format.annotation.DateTimeFormat;

public class UserVO {
	@DateTimeFormat(pattern = "yyyy-MM-dd")
	private String uno;
	private String uname;
	private String uid;
	private String upw;
	@DateTimeFormat(pattern = "yyyy-MM-dd")
	private Date ubirth;
	private String uaddr;
	private char ugender;
	private String uphone;
	private String umail;
	private String uprofile;
	private Date uinsertdate;
	private Date uupdatedate;
	private char udeleteyn;
	private String urole;
	private String utempyn;
	
	// デフォルトコンストラクタ (기본 생성자)
	public UserVO() {
		super();
	}
	public UserVO(String uno, String uname, String uid, String upw,
			Date ubirth, String uaddr, char ugender, String uphone, String umail, String uprofile, Date uinsertdate, Date uupdatedate, char udeleteyn, String urole, String utempyn) {
		super();
		this.uno = uno;
		this.uname = uname;
		this.uid = uid;
		this.upw = upw;
		this.ubirth = ubirth;
		this.uaddr = uaddr;
		this.ugender = ugender;
		this.uphone = uphone;
		this.umail = umail;
		this.uprofile = uprofile;
		this.uinsertdate = uinsertdate;
		this.uupdatedate = uupdatedate;
		this.udeleteyn = udeleteyn;
		this.urole = urole;
		this.utempyn = utempyn;
		
	}
	public String getUno() {
		return uno;
	}
	public String getUname() {
		return uname;
	}
	public String getUid() {
		return uid;
	}
	public String getUpw() {
		return upw;
	}
	public Date getUbirth() {
		return ubirth;
	}
	public String getUaddr() {
		return uaddr;
	}
	public char getUgender() {
		return ugender;
	}
	public String getUphone() {
		return uphone;
	}
	public String getUmail() {
		return umail;
	}
	public String getUprofile() {
		return uprofile;
	}
	public Date getUinsertdate() {
		return uinsertdate;
	}
	public Date getUupdatedate() {
		return uupdatedate;
	}
	public char getUdeleteyn() {
		return udeleteyn;
	}
	public String getUrole() {
		return urole;
	}
	public String getutempyn() {
		return utempyn;
	}
	public void setUno(String uno) {
		this.uno = uno;
	}
	public void setUname(String uname) {
		this.uname = uname;
	}
	public void setUid(String uid) {
		this.uid = uid;
	}
	public void setUpw(String upw) {
		this.upw = upw;
	}
	public void setUbirth(Date ubirth){
		this.ubirth = ubirth;
	}
	public void setUaddr(String uaddr) {
		this.uaddr = uaddr;
	}
	public void setUgender(char ugender) {
		this.ugender = ugender;
	}
	public void setUphone(String uphone) {
		this.uphone = uphone;
	}
	public void setUmail(String umail) {
		this.umail = umail;
	}
	public void setUprofile(String uprofile) {
		this.uprofile = uprofile;
	}
	public void setUinsertdate(Date uinsertdate) {
		this.uinsertdate = uinsertdate;
	}
	public void setUupdatedate(Date uupdatedate) {
		this.uupdatedate = uupdatedate;
	}
	public void setUdeleteyn(char udeleteyn) {
		this.udeleteyn = udeleteyn;
	}
	public void setUrole(String urole) {
		this.urole = urole;
	}
	public void setUtempyn(String utempyn) {
		this.utempyn = utempyn;
	}
	@Override
	public String toString() {
		return "UserVO [uno=" + uno + ",uname=" + uname +", uid=" + uid +", upw=" + upw +", ubirth=" + ubirth 
				+", uaddr=" + uaddr +", ugender=" + ugender +",uphone=" + uphone +", umail=" + umail +", uprofile=" + uprofile 
				+", uinsertdate=" + uinsertdate +", uupdatedate=" + uupdatedate +", udeleteyn=" + udeleteyn +", urole=" + urole +", utempyn=" + utempyn + "]";
	}
}
