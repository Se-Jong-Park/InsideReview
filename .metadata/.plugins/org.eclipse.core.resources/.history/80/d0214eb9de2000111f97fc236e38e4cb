<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace = 'com.jeonju.movie.app.mapper.UserMapper.'>
	<select id="maxno" resultType='java.lang.Integer'>
		SELECT IFNULL(MAX(SUBSTRING(UNO,10,3)),0)+1 AS 'MAXNO'
		FROM	USER
		WHERE	SUBSTRING(UNO,2,8) = DATE_FORMAT(NOW(),'%Y%m%d')
	</select>
	<!-- 회원가입 ISNERT -->
	<insert id="userJoin" parameterType="UserVO">
		INSERT INTO USER
		(UNO, UNAME, UID, UPW, UBIRTH,
		 UADDR, UGENDER, UPHONE, UMAIL, UPROFILE, 
		 UROLE, UINSERTDATE, UUPDATEDATE, UDELETEYN)
		VALUES
		(#{uno},#{uname},#{uid},#{upw},#{ubirth},
		#{uaddr},#{ugender},#{uphone},#{umail},
		#{uprofile},#{urole}, NOW(), NOW(), 'Y');
	</insert>
	<!-- 아이디 중복 체크 -->
	<select id="IdCheck" parameterType="java.lang.String" resultType="java.lang.Integer">
		SELECT	COUNT(UID)
		FROM	USER
		WHERE	UID = #{uid}
	</select>
	
	<select id="selectID" parameterType="java.lang.String" resultType="UserVO">
		SELECT
			*
		FROM	USER
		WHERE
				UDELETEYN = 'Y'
		AND UID = #{uid}
	</select>
	<!-- 회원정보 수정용 -->
	<update id="userUpdate" parameterType="UserVO">
		UPDATE	USER
		SET
			UNAME	= #{uname},
			UBIRTHDAY	= #{ubirth},
			UADDR	= #{uaddr},
			UGENDER	= #{ugender},
			UPHONE	= #{uphone},
			UMAIL	= #{umail},
			UPROFILE	= #{uprofile},
			UUPDATEDATE	= NOW()
			
		WHERE UNO = #{uno}
	</update>
	
	<!-- 회원정보 삭제 -->
	<update id="userDelete" parameterType="java.lang.String">
		UPDATE	USER
		SET
			UDELETEYN = 'N',
			UUPDATEDATE = NOW()
		WHERE
			UNO = #{uno}
			
	</update>
	
	<!-- 전체 조회 -->
	<select id="userList" resultType="userVO" parameterType="SearchCondition">
		SELECT
				UNO,UNAME,UID,UBIRTH,UPHONE,UPROFILE,UINSERTDATE
		FROM	USER
		WHERE	UDELETEYN = 'Y'
		<include refid="searchCondition">
		ORDER BY UINSERTDATE ASC, UNAME DESC
		LIMIT	#{offset}, #{pageSize}
		</include>
	</select>
	<!--  전체 회원수 -->
	<select id="userCnt" resultType="java.lang.Integer" parameterType="SearchCondition">
		SELECT
				COUNT(*)
		FROM	USER
		WHERE	UDELETEYN = 'Y'
		<include refid="searchCondition"/>
	</select>
	<!-- 회원 상세 조회 -->
	<select id="userOne" parameterType="java.lang.String" resultType="UserVO">
		SELECT
				*
		FROM	USER
		WHERE	UNO = #{uno}
	</select>
	
	<sql id="searchCondition">
		<choose>
			<when test='option == "NA"'>
				AND UNAME LIKE CONCAT('%',#{keyword},'%')
			</when>
			<when test='option == "ID"'>
				AND UID LIKE CONCAT('%',#{keyword},'%')
			</when>
		</choose>
	</sql>
	
	<select id="searchPW" parameterType="UserVO" resultType="java.lang.String">
		SELECT
				UID
		FROM	USER
		WHERE	UDELETEYN = 'Y'
		AND		UNAME = #{uname}
		AND		UID = #{uid}
		AND		UPHONE = #{uphone}
	</select>
</mapper>