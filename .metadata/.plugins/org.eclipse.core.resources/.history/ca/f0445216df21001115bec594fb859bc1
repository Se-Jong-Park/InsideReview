package com.jeonju.movie.comm;

import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.concurrent.atomic.AtomicInteger;

/*
 * UNO 자동생성기
 * 형식 : yyMMdd(6자리) + 순번(6자리) = 총 12자리 ex)260317000001
 * */

public class UnoGenerator {
	private static final AtomicInteger counter = new AtomicInteger(0);
	
	public static String generate() {
		String datePart = new SimpleDateFormat("yyMMdd").format(new Date());
		int seq = counter.incrementAndGet() % 1000000;
		return datePart + String.format("%06d", seq);
	}
}
