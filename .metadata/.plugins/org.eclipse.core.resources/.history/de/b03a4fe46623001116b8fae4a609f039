<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c"   uri="http://java.sun.com/jsp/jstl/core" %>
<%@ taglib prefix="fmt" uri="http://java.sun.com/jsp/jstl/fmt" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${movie.mtitle} — CINEVERSE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard/dist/web/static/pretendard.css">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/main.css">
    <style>
        /* ── 게시판 헤더 (영화 정보) ── */
        .board-hero {
            padding-top: 64px;
            min-height: 320px;
            position: relative;
            display: flex; align-items: flex-end;
            background: linear-gradient(135deg, #0a0a0f 0%, #13131a 100%);
            overflow: hidden;
        }
        .board-hero-bg {
            position: absolute; inset: 0;
            background-size: cover; background-position: center;
            opacity: .18; filter: blur(2px);
        }
        .board-hero-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(10,10,15,1) 0%, rgba(10,10,15,.4) 100%);
        }
        .board-hero-content {
            position: relative; z-index: 2;
            padding: 40px 48px;
            display: flex; gap: 32px; align-items: flex-end;
            width: 100%;
        }
        .board-poster {
            width: 110px; height: 165px;
            border-radius: 8px; overflow: hidden;
            flex-shrink: 0;
            box-shadow: 0 8px 32px rgba(0,0,0,.6);
        }
        .board-poster img { width: 100%; height: 100%; object-fit: cover; }
        .board-poster-ph {
            width: 100%; height: 100%;
            background: var(--bg-hover);
            display: flex; align-items: center; justify-content: center;
            font-family: 'Bebas Neue', cursive;
            font-size: .75rem; letter-spacing: 1px;
            color: var(--text-muted);
        }
        .board-meta { flex: 1; }
        .board-genre-tag {
            display: inline-block;
            font-size: .7rem; font-weight: 700; letter-spacing: 1.5px;
            color: var(--accent); border: 1px solid var(--accent);
            padding: 3px 10px; border-radius: 3px; margin-bottom: 10px;
        }
        .board-movie-title {
            font-family: 'Bebas Neue', cursive;
            font-size: clamp(1.8rem, 4vw, 3rem);
            letter-spacing: 2px; line-height: 1;
            margin-bottom: 10px;
        }
        .board-movie-info {
            display: flex; gap: 16px; align-items: center;
            font-size: .8rem; color: var(--text-secondary);
            margin-bottom: 14px;
        }
        .board-avg-score {
            display: flex; align-items: center; gap: 6px;
        }
        .stars-display { color: var(--gold); font-size: 1rem; letter-spacing: 2px; }
        .score-num {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.4rem; color: var(--gold);
        }
        .score-count { font-size: .75rem; color: var(--text-muted); }
        .btn-rate {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 18px;
            background: rgba(245,197,24,.1);
            border: 1px solid rgba(245,197,24,.4);
            color: var(--gold); border-radius: 5px;
            font-size: .82rem; font-weight: 700; cursor: pointer;
            transition: background .2s;
        }
        .btn-rate:hover { background: rgba(245,197,24,.2); }

        /* ── 게시판 본문 ── */
        .board-wrap {
            max-width: 960px; margin: 0 auto;
            padding: 40px 24px;
        }
        .board-toolbar {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px;
        }
        .board-count {
            font-size: .85rem; color: var(--text-secondary);
        }
        .board-count span { color: var(--accent); font-weight: 700; }
        .btn-write {
            padding: 9px 22px;
            background: var(--accent); color: #fff;
            border: none; border-radius: 5px;
            font-size: .82rem; font-weight: 700; cursor: pointer;
            text-decoration: none; display: inline-block;
            transition: background .2s;
        }
        .btn-write:hover { background: #c40812; }

        /* ── 게시물 테이블 ── */
        .board-table { width: 100%; border-collapse: collapse; }
        .board-table thead tr {
            border-bottom: 1px solid var(--border);
        }
        .board-table th {
            padding: 10px 12px;
            font-size: .75rem; font-weight: 700;
            color: var(--text-muted); letter-spacing: .5px;
            text-align: left;
        }
        .board-table th.center { text-align: center; }
        .board-table tbody tr {
            border-bottom: 1px solid var(--border);
            transition: background .15s; cursor: pointer;
        }
        .board-table tbody tr:hover { background: var(--bg-hover); }
        .board-table td {
            padding: 14px 12px;
            font-size: .85rem; color: var(--text-primary);
        }
        .board-table td.center { text-align: center; }
        .td-title { max-width: 480px; }
        .td-title a {
            color: var(--text-primary); text-decoration: none;
            display: block;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .td-title a:hover { color: var(--accent); }
        .td-author { color: var(--text-secondary); font-size: .8rem; }
        .td-date   { color: var(--text-muted);      font-size: .78rem; white-space: nowrap; }
        .td-cnt    { color: var(--text-muted);      font-size: .78rem; }

        /* 공지 배지 */
        .badge-notice {
            display: inline-block;
            font-size: .65rem; font-weight: 700; letter-spacing: .5px;
            background: var(--accent); color: #fff;
            padding: 2px 6px; border-radius: 3px; margin-right: 6px;
            vertical-align: middle;
        }

        /* 빈 목록 */
        .board-empty {
            text-align: center; padding: 80px 0;
            color: var(--text-muted); font-size: .9rem;
        }
        .board-empty p { margin-top: 8px; font-size: .8rem; }

        /* ── 페이지네이션 ── */
        .pagination {
            display: flex; justify-content: center; gap: 6px;
            margin-top: 32px;
        }
        .page-btn {
            width: 34px; height: 34px; border-radius: 5px;
            display: flex; align-items: center; justify-content: center;
            background: var(--bg-card); border: 1px solid var(--border);
            color: var(--text-secondary); font-size: .82rem; cursor: pointer;
            text-decoration: none; transition: all .2s;
        }
        .page-btn:hover, .page-btn.active {
            background: var(--accent); border-color: var(--accent);
            color: #fff;
        }

        /* ── 별점 팝업 ── */
        .popup-backdrop {
            position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,.75);
            backdrop-filter: blur(4px);
            display: flex; align-items: center; justify-content: center;
            animation: fadeIn .25s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }
        .popup-box {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 40px 48px;
            width: 100%; max-width: 420px;
            text-align: center;
            box-shadow: 0 24px 64px rgba(0,0,0,.7);
            animation: slideUp .3s cubic-bezier(.4,0,.2,1);
        }
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .popup-movie-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 1.6rem; letter-spacing: 2px;
            margin-bottom: 6px;
        }
        .popup-sub {
            font-size: .82rem; color: var(--text-muted);
            margin-bottom: 28px;
        }

        /* 별점 입력 */
        .star-input {
            display: flex; justify-content: center; gap: 8px;
            margin-bottom: 12px;
            flex-direction: row-reverse; /* CSS only 별점 트릭 */
        }
        .star-input input[type="radio"] { display: none; }
        .star-input label {
            font-size: 2.4rem; cursor: pointer;
            color: var(--text-muted);
            transition: color .15s, transform .15s;
        }
        /* 호버: 해당 별과 그 이전 별 모두 금색 */
        .star-input label:hover,
        .star-input label:hover ~ label,
        .star-input input:checked ~ label {
            color: var(--gold);
            transform: scale(1.1);
        }
        .score-label {
            font-family: 'Bebas Neue', cursive;
            font-size: 2rem; color: var(--gold);
            min-height: 2.4rem;
            margin-bottom: 24px;
        }

        .popup-actions { display: flex; gap: 10px; }
        .btn-submit-rate {
            flex: 1; padding: 12px;
            background: var(--accent); color: #fff;
            border: none; border-radius: 8px;
            font-size: .9rem; font-weight: 700; cursor: pointer;
            transition: background .2s;
        }
        .btn-submit-rate:hover { background: #c40812; }
        .btn-skip {
            flex: 1; padding: 12px;
            background: transparent; color: var(--text-secondary);
            border: 1px solid var(--border); border-radius: 8px;
            font-size: .9rem; cursor: pointer;
            transition: border-color .2s;
        }
        .btn-skip:hover { border-color: var(--text-secondary); }

        /* ── 반응형 ── */
        @media (max-width: 768px) {
            .board-hero-content { padding: 24px 20px; flex-direction: column; align-items: flex-start; }
            .board-wrap { padding: 24px 16px; }
            .popup-box { margin: 0 16px; padding: 32px 24px; }
            .board-table th:nth-child(3),
            .board-table td:nth-child(3) { display: none; }
        }
    </style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
    <a href="${pageContext.request.contextPath}/" class="nav-logo">CINEVERSE</a>
    <div class="nav-links">
        <a href="${pageContext.request.contextPath}/main">홈</a>
        <a href="${pageContext.request.contextPath}/movie/list">커뮤니티</a>
    </div>
    <div class="nav-right">
        <c:choose>
            <c:when test="${not empty sessionScope.loginUser}">
                <span style="font-size:.82rem; color:var(--text-secondary);">${sessionScope.loginUser.nickname}</span>
                <a href="${pageContext.request.contextPath}/member/logout" class="btn-logout">로그아웃</a>
            </c:when>
            <c:otherwise>
                <a href="${pageContext.request.contextPath}/member/login" class="btn-login">로그인</a>
            </c:otherwise>
        </c:choose>
    </div>
</nav>

<!-- ── 게시판 헤더 (영화 정보) ── -->
<div class="board-hero">
    <c:if test="${not empty movie.mposter}">
        <div class="board-hero-bg"
             style="background-image:url('${pageContext.request.contextPath}/resources/upload/${movie.mposter}')">
        </div>
    </c:if>
    <div class="board-hero-overlay"></div>
    <div class="board-hero-content">
        <div class="board-poster">
            <c:choose>
                <c:when test="${not empty movie.mposter}">
                    <img src="${pageContext.request.contextPath}/resources/upload/${movie.mposter}" alt="${movie.mtitle}">
                </c:when>
                <c:otherwise>
                    <div class="board-poster-ph">${movie.mtitle}</div>
                </c:otherwise>
            </c:choose>
        </div>
        <div class="board-meta">
            <c:if test="${not empty movie.mgenre}">
                <span class="board-genre-tag">${movie.mgenre}</span>
            </c:if>
            <div class="board-movie-title">${movie.mtitle}</div>
            <div class="board-movie-info">
                <c:if test="${not empty movie.mdirecter}">
                    <span>감독 ${movie.mdirecter}</span>
                </c:if>
                <c:if test="${not empty movie.mreleasedate}">
                    <span>${movie.mreleasedate}</span>
                </c:if>
            </div>
            <div class="board-avg-score">
                <c:choose>
                    <c:when test="${avgScore > 0}">
                        <span class="stars-display">
                            <c:forEach begin="1" end="5" var="i">
                                <c:choose>
                                    <c:when test="${i <= avgScore}">★</c:when>
                                    <c:otherwise>☆</c:otherwise>
                                </c:choose>
                            </c:forEach>
                        </span>
                        <span class="score-num">
                            <fmt:formatNumber value="${avgScore}" pattern="0.0"/>
                        </span>
                        <span class="score-count">/ 5.0</span>
                    </c:when>
                    <c:otherwise>
                        <span class="score-count">아직 별점이 없어요</span>
                    </c:otherwise>
                </c:choose>
                <button class="btn-rate" onclick="openRatingPopup()">★ 별점 등록</button>
            </div>
        </div>
    </div>
</div>

<!-- ── 게시판 본문 ── -->
<div class="board-wrap">
    <div class="board-toolbar">
        <div class="board-count">
            총 <span>${boardList.size()}</span>개의 게시물
        </div>
        <a href="${pageContext.request.contextPath}/board/write?mno=${mno}" class="btn-write">✏ 글쓰기</a>
    </div>

    <table class="board-table">
        <thead>
            <tr>
                <th style="width:60px;" class="center">번호</th>
                <th>제목</th>
                <th style="width:100px;" class="center">작성자</th>
                <th style="width:100px;" class="center">날짜</th>
                <th style="width:60px;"  class="center">조회</th>
            </tr>
        </thead>
        <tbody>
            <c:choose>
                <c:when test="${not empty boardList}">
                    <c:forEach var="board" items="${boardList}" varStatus="st">
                        <tr onclick="location.href='${pageContext.request.contextPath}/board/detail?bno=${board.bno}'">
                            <td class="center" style="color:var(--text-muted); font-size:.78rem;">
                                <c:choose>
                                    <c:when test="${board.bnotice == 1}">
                                        <span class="badge-notice">공지</span>
                                    </c:when>
                                    <c:otherwise>${st.index + 1}</c:otherwise>
                                </c:choose>
                            </td>
                            <td class="td-title">
                                <a href="${pageContext.request.contextPath}/board/detail?bno=${board.bno}">
                                    ${board.btitle}
                                </a>
                            </td>
                            <td class="td-author center">${board.bid}</td>
                            <td class="td-date center">${board.binsertdate}</td>
                            <td class="td-cnt center">${board.bcnt}</td>
                        </tr>
                    </c:forEach>
                </c:when>
                <c:otherwise>
                    <tr>
                        <td colspan="5">
                            <div class="board-empty">
                                아직 게시물이 없어요
                                <p>이 영화의 첫 번째 리뷰를 작성해보세요!</p>
                            </div>
                        </td>
                    </tr>
                </c:otherwise>
            </c:choose>
        </tbody>
    </table>

    <%-- 페이지네이션 (추후 PageHandler 연동 시 활용) --%>
    <%--
    <div class="pagination">
        <a href="?mno=${mno}&page=${ph.startPage - 1}" class="page-btn">‹</a>
        <c:forEach begin="${ph.startPage}" end="${ph.endPage}" var="p">
            <a href="?mno=${mno}&page=${p}" class="page-btn ${ph.currentPage == p ? 'active' : ''}">${p}</a>
        </c:forEach>
        <a href="?mno=${mno}&page=${ph.endPage + 1}" class="page-btn">›</a>
    </div>
    --%>
</div>

<!-- ── 별점 팝업 ── -->
<c:if test="${showRatingPopup}">
<div class="popup-backdrop" id="ratingPopup">
    <div class="popup-box">
        <div class="popup-movie-title">${movie.mtitle}</div>
        <div class="popup-sub">이 영화 어떠셨나요? 별점을 남겨주세요 ✨</div>

        <form action="${pageContext.request.contextPath}/board/rating" method="post" id="ratingForm">
            <input type="hidden" name="mno" value="${mno}">

            <!-- 별점 선택 (5 → 1 역순으로 배치, CSS row-reverse로 좌→우 표시) -->
            <div class="star-input">
                <input type="radio" id="s5" name="ratscore" value="5">
                <label for="s5" title="5점">★</label>
                <input type="radio" id="s4" name="ratscore" value="4">
                <label for="s4" title="4점">★</label>
                <input type="radio" id="s3" name="ratscore" value="3">
                <label for="s3" title="3점">★</label>
                <input type="radio" id="s2" name="ratscore" value="2">
                <label for="s2" title="2점">★</label>
                <input type="radio" id="s1" name="ratscore" value="1">
                <label for="s1" title="1점">★</label>
            </div>
            <div class="score-label" id="scoreLabel">★ 를 선택해주세요</div>

            <div class="popup-actions">
                <button type="submit" class="btn-submit-rate">등록하기</button>
                <button type="button" class="btn-skip" onclick="closeRatingPopup()">다음에 할게요</button>
            </div>
        </form>
    </div>
</div>
</c:if>

<script src="${pageContext.request.contextPath}/resources/js/main.js"></script>
<script>
    /* ── 별점 팝업 ── */
    const scoreTexts = { 1:'★ 별로예요', 2:'★★ 그저 그래요', 3:'★★★ 보통이에요', 4:'★★★★ 좋아요!', 5:'★★★★★ 최고예요!' };

    // 별점 선택 시 라벨 업데이트
    document.querySelectorAll('.star-input input').forEach(input => {
        input.addEventListener('change', () => {
            document.getElementById('scoreLabel').textContent = scoreTexts[input.value] || '';
        });
    });

    function openRatingPopup() {
        const popup = document.getElementById('ratingPopup');
        if (popup) {
            popup.style.display = 'flex';
        } else {
            // 이미 별점 등록한 경우 팝업이 없으므로 알림
            alert('이미 별점을 등록하셨어요!');
        }
    }

    function closeRatingPopup() {
        document.getElementById('ratingPopup').style.display = 'none';
        // 세션에 기록해서 새로고침해도 안 뜨게 처리
        fetch('${pageContext.request.contextPath}/board/ratingSkip?mno=${mno}');
    }

    // 폼 제출 전 별점 선택 확인
    document.getElementById('ratingForm') && document.getElementById('ratingForm').addEventListener('submit', function(e) {
        const checked = document.querySelector('.star-input input:checked');
        if (!checked) {
            e.preventDefault();
            alert('별점을 선택해주세요!');
        }
    });
</script>
</body>
</html>
	