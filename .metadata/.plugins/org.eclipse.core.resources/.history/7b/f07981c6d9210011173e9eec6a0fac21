<%@ page language="java" contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>
<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>게시물 수정 — CINEVERSE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="${pageContext.request.contextPath}/resources/css/main.css">
    <script src="${pageContext.request.contextPath}/resources/smarteditor/js/smarteditor2.js" charset="UTF-8"></script>
    <style>
        .write-wrap {
            max-width: 900px; margin: 0 auto;
            padding: 100px 24px 60px;
        }
        .write-header {
            margin-bottom: 32px;
            padding-bottom: 20px;
            border-bottom: 1px solid var(--border);
        }
        .write-movie-tag {
            display: inline-block;
            font-size: .7rem; font-weight: 700; letter-spacing: 1.5px;
            color: var(--gold); border: 1px solid var(--gold);
            padding: 3px 10px; border-radius: 3px; margin-bottom: 10px;
        }
        .write-page-title {
            font-family: 'Bebas Neue', cursive;
            font-size: 2rem; letter-spacing: 2px;
        }
        .write-form { display: flex; flex-direction: column; gap: 16px; }
        .form-group { display: flex; flex-direction: column; gap: 6px; }
        .form-label {
            font-size: .78rem; font-weight: 700;
            color: var(--text-secondary); letter-spacing: .5px;
        }
        .form-input {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 7px;
            color: var(--text-primary);
            font-family: inherit; font-size: .9rem;
            padding: 12px 16px;
            transition: border-color .2s; outline: none;
        }
        .form-input:focus { border-color: var(--accent); }
        .editor-wrap {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 7px; overflow: hidden;
        }
        .editor-wrap:focus-within { border-color: var(--accent); }
        #smart-editor { min-height: 400px; display: none; }

        /* 기존 첨부파일 표시 */
        .current-file {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 14px;
            background: var(--bg-hover);
            border: 1px solid var(--border);
            border-radius: 7px; font-size: .82rem;
        }
        .current-file a { color: var(--accent); text-decoration: none; }
        .current-file a:hover { text-decoration: underline; }
        .file-label {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 9px 18px;
            background: var(--bg-hover);
            border: 1px dashed var(--border);
            border-radius: 7px;
            color: var(--text-secondary);
            font-size: .82rem; cursor: pointer;
            transition: border-color .2s, color .2s;
        }
        .file-label:hover { border-color: var(--accent); color: var(--text-primary); }
        .file-name { font-size: .78rem; color: var(--text-muted); margin-left: 8px; }
        input[type="file"] { display: none; }
        .write-actions {
            display: flex; justify-content: flex-end; gap: 10px;
            padding-top: 8px;
        }
        .btn-cancel {
            padding: 11px 28px; background: transparent;
            border: 1px solid var(--border); color: var(--text-secondary);
            border-radius: 7px; font-size: .88rem; cursor: pointer;
            text-decoration: none; display: inline-block; text-align: center;
            transition: all .2s;
        }
        .btn-cancel:hover { border-color: var(--text-secondary); color: var(--text-primary); }
        .btn-submit {
            padding: 11px 32px;
            background: var(--accent); color: #fff;
            border: none; border-radius: 7px;
            font-size: .88rem; font-weight: 700;
            cursor: pointer; transition: background .2s;
        }
        .btn-submit:hover { background: #c40812; }
    </style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
    <a href="${pageContext.request.contextPath}/" class="nav-logo">CINEVERSE</a>
    <div class="nav-links">
        <a href="${pageContext.request.contextPath}/">홈</a>
        <a href="${pageContext.request.contextPath}/movie/list" class="active">커뮤니티</a>
    </div>
    <div class="nav-right">
        <c:choose>
            <c:when test="${not empty sessionScope.loginUser}">
                <span style="font-size:.82rem; color:var(--text-secondary);">${sessionScope.loginUser.nickname}</span>
                <a href="${pageContext.request.contextPath}/member/logout" class="btn-logout">로그아웃</a>
            </c:when>
            <c:otherwise>
                <a href="${pageContext.request.contextPath}/member/login" class="btn-login">로그인</a>
            </c:otherwise>
        </c:choose>
    </div>
</nav>

<div class="write-wrap">
    <div class="write-header">
        <div class="write-movie-tag">EDIT</div>
        <div class="write-page-title">게시물 수정</div>
    </div>

    <form id="editForm" action="${pageContext.request.contextPath}/board/edit"
          method="post" enctype="multipart/form-data" class="write-form">

        <input type="hidden" name="bno" value="${board.bno}">
        <input type="hidden" name="mno" value="${board.mno}">

        <!-- 제목 -->
        <div class="form-group">
            <label class="form-label">제목</label>
            <input type="text" name="btitle" class="form-input"
                   value="${board.btitle}" required maxlength="150">
        </div>

        <!-- 내용 (SmartEditor ONE — 기존 내용 로드) -->
        <div class="form-group">
            <label class="form-label">내용</label>
            <div class="editor-wrap">
                <textarea id="smart-editor" name="bcontent">${board.bcontent}</textarea>
                <div id="se2_divArea" style="min-height:400px;"></div>
            </div>
        </div>

        <!-- 기존 첨부파일 -->
        <c:if test="${not empty board.bupload}">
            <div class="form-group">
                <label class="form-label">현재 첨부파일</label>
                <div class="current-file">
                    📎 <a href="${pageContext.request.contextPath}/resources/upload/${board.bupload}"
                          download="${board.borfile}">${board.borfile}</a>
                    <span style="color:var(--text-muted); font-size:.75rem;">(새 파일 선택 시 교체됩니다)</span>
                </div>
            </div>
        </c:if>

        <!-- 파일 첨부 (새 파일로 교체) -->
        <div class="form-group">
            <label class="form-label">파일 첨부 (선택)</label>
            <div style="display:flex; align-items:center;">
                <label class="file-label" for="fileInput">📎 파일 선택</label>
                <span class="file-name" id="fileName">선택된 파일 없음</span>
                <input type="file" id="fileInput" name="uploadFile"
                       onchange="updateFileName(this)">
            </div>
        </div>

        <!-- 버튼 -->
        <div class="write-actions">
            <a href="${pageContext.request.contextPath}/board/detail?bno=${board.bno}"
               class="btn-cancel">취소</a>
            <button type="button" class="btn-submit" onclick="submitEdit()">수정 완료</button>
        </div>

    </form>
</div>

<script>
    /* ── SmartEditor ONE 초기화 (기존 내용 로드) ── */
    var oEditors = [];
    var sInitContent = document.getElementById("smart-editor").value;

    nhn.husky.EZCreator.createInIFrame({
        oAppRef: oEditors,
        elPlaceHolder: "se2_divArea",
        sSkinURI: "https://ssl.pstatic.net/static/nid/naver_se/se-2.2.8/SmartEditor2Skin.html",
        fCreator: "createSEditor2",
        fOnAppReady: function() {
            // 기존 내용 에디터에 로드
            if (sInitContent) {
                oEditors.getById["se2_divArea"].setContents(sInitContent);
            }
        }
    });

    /* ── 수정 폼 제출 ── */
    function submitEdit() {
        if (!document.querySelector('input[name="btitle"]').value.trim()) {
            alert('제목을 입력해주세요!');
            return;
        }
        try {
            oEditors.getById["se2_divArea"].exec("UPDATE_CONTENTS_FIELD", []);
        } catch(e) {
            console.log("에디터 내용 저장 실패");
        }
        var content = document.getElementById("smart-editor").value;
        if (!content || content.trim() === '') {
            alert('내용을 입력해주세요!');
            return;
        }
        document.getElementById("editForm").submit();
    }

    /* ── 파일명 표시 ── */
    function updateFileName(input) {
        var fileName = input.files.length > 0 ? input.files[0].name : '선택된 파일 없음';
        document.getElementById('fileName').textContent = fileName;
    }
</script>
</body>
</html>
